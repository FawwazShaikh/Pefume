generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  phone     String?
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  addresses Address[]
  cartItems CartItem[]
  orders    Order[]
  reviews   Review[]

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String   @default("India")
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
  @@map("addresses")
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  brand       String?
  featured    Boolean           @default(false)
  featuredOrder Int             @default(0)
  isActive    Boolean           @default(true)
  categoryId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  bottles     BottleInventory[]
  orderItems  OrderItem[]
  images      ProductImage[]
  variants    ProductVariant[]
  category    Category?         @relation(fields: [categoryId], references: [id])
  reviews     Review[]
  allowedBottles ProductAllowedBottle[]

  @@index([slug])
  @@index([name])
  @@index([categoryId])
  @@index([featured])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  imageUrl  String
  altText   String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id                String         @id @default(cuid())
  productId         String
  size              String
  price             Decimal        @db.Decimal(10, 2)
  stock             Int            @default(0)
  lowStockThreshold Int            @default(5)
  sku               String         @unique
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  volumeML          Int            @default(5)
  cartItems         CartItem[]
  inventoryLogs     InventoryLog[]
  orderItems        OrderItem[]
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model BottleInventory {
  id                  String              @id @default(cuid())
  productId           String
  bottleLabel         String
  bottleSizeML        Int
  remainingML         Int
  lowStockThresholdML Int                 @default(20)
  status              BottleStatus        @default(OPEN)
  purchaseDate        DateTime?
  supplier            String?
  batchNumber         String?
  costPrice           Decimal?            @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  product             Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements           InventoryMovement[]

  @@index([productId])
  @@index([status])
  @@map("bottle_inventory")
}

model InventoryMovement {
  id         String          @id @default(cuid())
  bottleId   String
  type       MovementType
  quantityML Int
  orderId    String?
  adminId    String?
  note       String?
  createdAt  DateTime        @default(now())
  bottle     BottleInventory @relation(fields: [bottleId], references: [id], onDelete: Cascade)

  @@index([bottleId])
  @@index([orderId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model CartItem {
  id                    String         @id @default(cuid())
  userId                String
  variantId             String
  quantity              Int            @default(1)
  bottleId              String?
  bottleName            String?
  bottleColor           String?
  bottleImage           String?
  bottlePriceAdjustment Decimal?       @db.Decimal(10, 2)
  bottleSku             String?
  bottleCategory        String?
  createdAt             DateTime       @default(now())
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant               ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cart_items")
}

model Order {
  id                String        @id @default(cuid())
  userId            String
  addressId         String
  subtotal          Decimal       @db.Decimal(10, 2)
  shippingFee       Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  status            OrderStatus   @default(PENDING)
  razorpayOrderId   String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  estimatedDelivery DateTime?
  orderReference    String?       @unique
  shippingMethod    String?
  trackingId        String?
  couponId          String?
  couponCode        String?
  discountAmount    Decimal?      @db.Decimal(10, 2)
  originalSubtotal  Decimal?      @db.Decimal(10, 2)
  finalSubtotal     Decimal?      @db.Decimal(10, 2)
  orderItems        OrderItem[]
  address           Address       @relation(fields: [addressId], references: [id])
  user              User          @relation(fields: [userId], references: [id])
  payment           Payment?
  reviews           Review[]
  coupon            Coupon?       @relation(fields: [couponId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderReference])
  @@map("orders")
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  productId       String
  variantId       String
  productName     String
  size            String
  priceAtPurchase Decimal        @db.Decimal(10, 2)
  quantity        Int
  createdAt       DateTime       @default(now())
  
  // Bottle snapshot fields
  bottleId              String?
  bottleName            String?
  bottleColor           String?
  bottleImage           String?
  bottlePriceAdjustment Decimal? @db.Decimal(10, 2)
  bottleSku             String?
  bottleCategory        String?

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  provider      PaymentMethod
  transactionId String?
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([transactionId])
  @@map("payments")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  orderId   String?
  rating    Int
  title     String?
  comment   String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order?   @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([approved])
  @@map("reviews")
}

model InventoryLog {
  id         String              @id @default(cuid())
  variantId  String
  oldStock   Int
  newStock   Int
  changeType InventoryChangeType
  note       String?
  createdAt  DateTime            @default(now())
  variant    ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
  @@map("inventory_logs")
}

model StoreSetting {
  id                    String   @id @default("default")
  storeName             String   @default("Decant Atelier")
  supportEmail          String   @default("concierge@decantatelier.com")
  supportPhone          String   @default("+91 97681 88453")
  codEnabled            Boolean  @default(true)
  shippingCharges       Decimal  @default(100.00) @db.Decimal(10, 2)
  freeShippingThreshold Decimal  @default(1999.00) @db.Decimal(10, 2)
  razorpayKey           String   @default("rzp_test_AtelierKey2026")
  razorpaySecret        String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("store_settings")
}

model Campaign {
  id             String    @id @default(cuid())
  isActive       Boolean   @default(false)
  title          String    @default("Special Offer")
  subheading     String?
  imageUrl       String?
  badge          String?
  displayPrice   String?
  ctaText        String    @default("Shop Now")
  ctaDestination String    @default("shop")
  displayMode    String    @default("once_per_day")
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("campaigns")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  OUT_FOR_DELIVERY
}

enum PaymentMethod {
  COD
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum InventoryChangeType {
  ORDER
  RESTOCK
  MANUAL_EDIT
}

enum BottleStatus {
  OPEN
  EMPTY
  RETIRED
}

enum MovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  CANCELLATION
}

model Coupon {
  id                 String       @id @default(cuid())
  code               String       @unique
  type               CouponType
  value              Decimal      @db.Decimal(10, 2)
  minimumOrderValue  Decimal      @default(0) @db.Decimal(10, 2)
  maximumDiscount    Decimal?     @db.Decimal(10, 2)
  isActive           Boolean      @default(true)
  isArchived         Boolean      @default(false)
  launchOnly         Boolean      @default(false)
  startsAt           DateTime?
  expiresAt          DateTime?
  usageLimit         Int          @default(1)
  perUserLimit       Int          @default(1)
  usedCount          Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  orders             Order[]

  @@index([code])
  @@map("coupons")
}

enum CouponType {
  FIXED
  PERCENT
}

enum BottleCategory {
  CLASSIC_MINI
  TRAVEL_SAFE
  CLASSIC_METAL
  PREMIUM
  LUXURY
}

model BottleCatalog {
  id                  String                   @id @default(cuid())
  sku                 String                   @unique
  name                String
  finish              String
  category            BottleCategory           @default(CLASSIC_MINI)
  imageKey            String
  priceAdjustment     Decimal                  @default(0) @db.Decimal(10, 2)
  badge               String?
  sortOrder           Int                      @default(0)
  isActive            Boolean                  @default(true)
  isDefault           Boolean                  @default(false)
  stock               Int                      @default(100)
  lowStockThreshold   Int                      @default(10)
  trackInventory      Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  sizeAvailabilities  BottleSizeAvailability[]
  productRestrictions ProductAllowedBottle[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("bottle_catalog")
}

model BottleSizeAvailability {
  id        String        @id @default(cuid())
  bottleId  String
  size      String
  enabled   Boolean       @default(true)
  bottle    BottleCatalog @relation(fields: [bottleId], references: [id], onDelete: Cascade)

  @@unique([bottleId, size])
  @@index([bottleId])
  @@map("bottle_size_availabilities")
}

model ProductAllowedBottle {
  id        String        @id @default(cuid())
  productId String
  bottleId  String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  bottle    BottleCatalog @relation(fields: [bottleId], references: [id], onDelete: Cascade)

  @@unique([productId, bottleId])
  @@index([productId])
  @@index([bottleId])
  @@map("product_allowed_bottles")
}
