# Root Gitignore

# Ignore duplicate images folder (use frontend/public/images/ instead)
/images/

# Ignore WhatsApp zip files
*.zip

# Ignore inspection and temporary HTML files generated by tools
*_inspect.html
frontend/public/*_inspect.html

# Ignore temporary media/screenshots generated by tools
**/media__*.png

# Ignore local environment, dependency, and temporary folders
node_modules/
.env
.clerk/
scratch/
dist/
build/
